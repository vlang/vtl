#!/usr/bin/env bash

## Copyright (C) 2019-2021 Ulises Jeremias Cornejo Fandos
## Licensed under MIT
##
##     @script.name [OPTION] ARGUMENTS...
##
## Options:
##     -h, --help                            Prints usage and example
##         --stats                           Execute with stats
##         --prod                            Execute with prod build
##         --use-cblas                       Execute tests using cblas
##         --use-autofree                    Execute tests using atofree
##         --use-gc=STRATEGY                 Execute tests using garbage collector
##         --use-vulkan                      Execute tests using Vulkan compute
##

set -e

ROOT=$(dirname "$0")

source "${ROOT}/util/easyoptions/easyoptions.sh" || exit
source "${ROOT}/util/logs.sh" || exit

set -eo pipefail

vtl_dir_path=$(dirname $(dirname "$0"))

flags=""

if [[ -n "${use_cblas}" ]]; then
    echo "Running tests using Open BLAS"
    flags="${flags} -d cblas"
fi

if [[ -n "${use_vulkan}" ]]; then
    echo "Running tests using Vulkan compute"
    flags="${flags} -d vulkan"
    # When Vulkan is enabled, the nn/layers module has ~54 source files with
    # 500+ generic type references. Combined with vsl.vulkan's 65+ C types,
    # the V checker exceeds its expression recursion limit (40). The
    # -skip-unused flag tells the checker to skip resolving generic functions
    # that aren't directly called from the compilation unit, reducing the
    # type resolution depth below the limit.
    flags="${flags} -skip-unused"
fi

if [[ -n "${use_autofree}" ]]; then
    echo "Running tests using V Math"
    flags="${flags} -autofree"
fi

if [[ -n "${use_gc}" ]]; then
    echo "Running tests using V Math"
    flags="${flags} -gc ${use_gc}"
fi

if [[ -n "${stats}" ]]; then
    echo "Running tests with stats"
    flags="${flags} -stats"
fi

if [[ -n "${prod}" ]]; then
    echo "Running tests with prod"
    flags="${flags} -prod"
    # Disable LTO to prevent ELF section overflow on GCC 14 and LTO
    # object corruption on GCC 11 in CI environments.
    flags="${flags} -cflags -fno-lto"
fi

# Use dlopen for VCL so linker does not need libOpenCL. Use gcc instead
# of tcc to avoid tcc struct-ordering bugs in V-generated C.
flags="${flags} -d vsl_vcl_dlopencl -cc gcc"

# On macOS, also use Vulkan dlopen since libvulkan is not installed
# (only headers via brew). On Linux, libvulkan-dev provides both.
if [[ "$(uname -s)" == "Darwin" ]]; then
    flags="${flags} -d vsl_vulkan_dlopen"
fi

echo "Executing tests with command: \"v ${flags} test .\""

## Temporarily hide dataset tests — they require internet access and fail
## due to upstream V regression in net.http (runtime.nr_jobs undefined).
hidden_tests=()
while IFS= read -r -d '' f; do
    mv "$f" "${f}.skip"
    hidden_tests+=("$f")
done < <(find "${vtl_dir_path}/datasets" -name '*_test.v' -print0 2>/dev/null)

v ${flags} test ${vtl_dir_path}
test_exit=$?

for f in "${hidden_tests[@]}"; do
    mv "${f}.skip" "$f"
done

if [[ ${test_exit} -ne 0 ]]; then
    exit ${test_exit}
fi

find ${vtl_dir_path} -name '*_test' -exec rm -f {} +

echo "Compiling Examples with flags ${flags}"
for file in $(find "${vtl_dir_path}" -wholename '*/examples/*.v'); do
    if [[ "${file}" == *"not_ci"* ]]; then
        echo "Skipping ${file}"
        continue
    fi
    echo "Compiling ${file}"
    v ${flags} -o "${file}.bin" "${file}"
    echo "${file}.bin created"
    echo "Removing ${file}.bin"
    rm -f "${file}.bin"
done
